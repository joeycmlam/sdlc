# Required (for agent.py only; agent_copilot.py uses the Copilot CLI keyring)
# GitHub personal access token with 'models:read' scope.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=github_pat_...

# Required for POST /github/issues — separate fine-grained token with
# 'repo' scope (Issues: write).  GH_TOKEN is preferred; falls back to
# GITHUB_TOKEN if unset.  Do NOT set this when using agent_copilot.py
# alone (the Copilot CLI manages its own credentials).
GH_TOKEN=github_pat_...

# Required for api_server.py + worker.py (Redis-backed sessions, Streams, Arq).
# Defaults to redis://localhost:6379/0 if unset.
REDIS_URL=redis://localhost:6379/0

# URL of this API server (used by agent_copilot.py for self-referential calls).
# Defaults to http://localhost:8000 if unset.
AGENT_API_URL=http://localhost:8000

# URL of the atlassian-bridge service (used for Confluence page fetching).
# Defaults to http://localhost:8002 if unset.
ATLASSIAN_BRIDGE_URL=http://localhost:8002

# Session TTL in seconds (default: 86400 = 24 h).
SESSION_TTL_SECONDS=86400
