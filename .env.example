# ─────────────────────────────────────────────────────────────────────────────
# SDLC Platform — root .env.example
#
# Copy to .env and fill in the required values before running:
#   cp .env.example .env
#   docker compose up --build
#
# Variables marked REQUIRED must be set.  Others have sensible defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub (copilot-agent) ────────────────────────────────────────────────────

# REQUIRED — GitHub PAT with 'models:read' scope (used by agent.py).
GITHUB_TOKEN=github_pat_...

# REQUIRED — Fine-grained PAT with Issues: write scope (used by POST /github/issues).
GH_TOKEN=github_pat_...

# ── Atlassian (jira-cli + atlassian-bridge) ───────────────────────────────────

# REQUIRED — Your Atlassian instance URL (no trailing slash).
ATLASSIAN_URL=https://your-org.atlassian.net

# REQUIRED — Service-account email.
ATLASSIAN_USER=your-email@example.com

# REQUIRED — API token from https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_API_TOKEN=your-api-token

# ── Redis ─────────────────────────────────────────────────────────────────────

# In docker-compose this is overridden per-service to redis://redis:6379/0.
# Change only when pointing at an external Redis instance.
REDIS_URL=redis://redis:6379/0

# Session TTL in seconds (default: 86400 = 24 h).
SESSION_TTL_SECONDS=86400

# ── copilot-agent service ─────────────────────────────────────────────────────

# URL of the atlassian-bridge service.
# In docker-compose this is set to http://atlassian-bridge:8002 automatically.
ATLASSIAN_BRIDGE_URL=http://atlassian-bridge:8002

# Self-referential URL used by agent_copilot.py for internal callbacks.
AGENT_API_URL=http://copilot-agent:8001

# ── atlassian-bridge service ──────────────────────────────────────────────────

# Server port for atlassian-bridge (default: 8002).
PORT=8002

# Comma-separated list of allowed CORS origins.
# Add your frontend origin when deploying to a public host.
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ────────────────────────────────────────────────────────

# Backend API URL used by Next.js server-side routes to proxy to copilot-agent.
# In docker-compose this is set at build time via --build-arg.
NEXT_PUBLIC_API_URL=http://copilot-agent:8001
